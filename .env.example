# Copy this file to apps/instagram_dashboard/.env if you want live Meta API features.
META_ACCESS_TOKEN=your_meta_access_token_here
IG_USER_ID=your_instagram_business_or_creator_user_id_here
GRAPH_API_VERSION=v25.0

# OpenAI STT for video/audio subtitles.
# Copy this file to .env at the project root and paste your real key there.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_STT_MODEL=gpt-4o-transcribe
LOCAL_WHISPER_MODEL=large-v3
OPENAI_STT_CHUNK_SECONDS=600
